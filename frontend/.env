# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=5000

# Authentication
VITE_JWT_TOKEN_KEY=auth_token
VITE_JWT_REFRESH_TOKEN_KEY=refresh_token

# Payment Gateway (Razorpay)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Application
VITE_APP_NAME=College Administration Management System
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_VIDEO_STREAMING=true
VITE_ENABLE_PAYMENTS=true

# Logging
VITE_ENABLE_DEBUG_LOGS=true
VITE_LOG_LEVEL=debug

# Session
VITE_SESSION_TIMEOUT=30
VITE_SESSION_STORAGE_KEY=session_data

# Video Configuration
VITE_MAX_VIDEO_UPLOAD_SIZE=500
VITE_SUPPORTED_VIDEO_FORMATS=mp4,webm,mov
VITE_VIDEO_QUALITY_OPTIONS=360p,480p,720p,1080p
